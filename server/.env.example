NODE_ENV=development
PORT=5000
SERVER_URL=http://localhost:5000
MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/eshaz_dream_world
# Production must be an Atlas mongodb+srv URI and must include the database name.
MONGODB_URI_PRODUCTION=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/eshaz_dream_world?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret
SESSION_IDLE_TIMEOUT_MINUTES=10
SESSION_ABSOLUTE_TIMEOUT_HOURS=8
SESSION_REMEMBER_TIMEOUT_DAYS=7
CLIENT_URL=http://localhost:5173,https://edw-phi.vercel.app
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Eshaz Dream World <no-reply@eshazdreamworld.com>
BANK_NAME=
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_BRANCH=
BANK_BRANCH_CODE=
BANK_TRANSFER_INSTRUCTIONS=Use the order number or your name as the transfer reference.
